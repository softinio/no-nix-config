{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(gh pr diff:*)",
      "Bash(grep:*)",
      "Bash(mill:*)",
      "Bash(python3:*)",
      "Bash(sbt:*)",
      "Bash(uv:*)",
      "Bash(xargs cat:*)"
    ],
    "deny": [],
    "ask": []
  },
  "model": "sonnet",
  "enabledMcpjsonServers": [
    "metals"
  ],
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
